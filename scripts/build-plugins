def plugin_versions_file() -> Path:
    return ROOT_DIR / "catalog" / "plugin-versions.json"


def json_dump(path: Path, payload: object) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def load_plugin_versions() -> dict[str, str]:
    versions = json.loads(plugin_versions_file().read_text(encoding="utf-8"))
    expected = set(PLUGIN_ORDER)
    actual = set(versions)
    missing = sorted(expected - actual)
    extra = sorted(actual - expected)
    if missing or extra:
        details: list[str] = []
        if missing:
            details.append(f"missing versions for: {', '.join(missing)}")
        if extra:
            details.append(f"unexpected versions for: {', '.join(extra)}")
        raise SystemExit(f"Invalid plugin version map in {plugin_versions_file()}: {'; '.join(details)}")
    return versions


def plugin_version(plugin: str) -> str:
    return load_plugin_versions()[plugin]


def ensure_skill_exists(skill: str) -> None:
    skill_dir = CATALOG_DIR / skill
    if not (skill_dir / "SKILL.md").exists():
        raise SystemExit(f"Missing canonical skill source: {skill_dir / 'SKILL.md'}")


PLATFORMS = ("claude", "codex")
SKILL_PLATFORM_DEFAULT = ("claude", "codex")
HOOK_PLATFORM_DEFAULT = ("claude",)
PACKAGING_FILENAME = "packaging.json"


def plugin_dir(plugin: str, platform: str) -> Path:
    return PLUGINS_DIR / platform / plugin


def _read_packaging(source_dir: Path) -> dict:
    path = source_dir / PACKAGING_FILENAME
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Invalid packaging metadata in {path}: {exc}")
    if not isinstance(data, dict):
        raise SystemExit(f"Packaging metadata must be an object: {path}")
    return data


def _platforms_from_packaging(source_dir: Path, default: tuple[str, ...]) -> list[str]:
    data = _read_packaging(source_dir)
    raw = data.get("platforms", list(default))
    if not isinstance(raw, list) or not all(isinstance(p, str) for p in raw):
        raise SystemExit(
            f"'platforms' in {source_dir / PACKAGING_FILENAME} must be a list of strings"
        )
    unknown = [p for p in raw if p not in PLATFORMS]
    if unknown:
        raise SystemExit(
            f"Unknown platforms {unknown!r} in {source_dir / PACKAGING_FILENAME}; "
            f"allowed: {list(PLATFORMS)}"
        )
    return raw


def skill_platforms(skill: str) -> list[str]:
    return _platforms_from_packaging(CATALOG_DIR / skill, SKILL_PLATFORM_DEFAULT)


def hook_platforms(hook: str) -> list[str]:
    return _platforms_from_packaging(HOOKS_CATALOG_DIR / hook, HOOK_PLATFORM_DEFAULT)


def skills_for(plugin: str, platform: str) -> list[str]:
    return [
        skill for skill in PLUGIN_DEFS[plugin].get("skills", [])
        if platform in skill_platforms(skill)
    ]


def hook_for(plugin: str, platform: str) -> str | None:
    hook_name = PLUGIN_DEFS[plugin].get("hooks")
    if not hook_name:
        return None
    if platform not in hook_platforms(hook_name):
        return None
    return hook_name


def copy_skills(plugin: str, platform: str) -> None:
    target_dir = plugin_dir(plugin, platform) / "skills"
    for skill in skills_for(plugin, platform):
        ensure_skill_exists(skill)
        shutil.copytree(
            CATALOG_DIR / skill,
            target_dir / skill,
            ignore=shutil.ignore_patterns("__pycache__", "*.pyc", PACKAGING_FILENAME),
        )


def external_skills_for(plugin: str, platform: str) -> list[dict]:
    # External skills currently default to both platforms; no sidecar scheme yet.
    del platform
    return EXTERNAL_SKILLS.get(plugin, [])


def fetch_external_skills(plugin: str, platform: str) -> None:
    entries = external_skills_for(plugin, platform)
    if not entries:
        return
    target_dir = plugin_dir(plugin, platform) / "skills"
    target_dir.mkdir(parents=True, exist_ok=True)
    for entry in entries:
        url = f"https://github.com/{entry['repo']}.git"
        fetch_external_skill(
            target_dir / entry["name"],
            url,
            entry["ref"],
            include=entry.get("include"),
        )


def fetch_external_skill(
    destination: Path,
    url: str,
    ref: str,
    include: list[str] | None = None,
) -> None:
    if destination.exists():
        shutil.rmtree(destination)
    with tempfile.TemporaryDirectory() as tmp:
        workdir = Path(tmp) / "clone"
        subprocess.run(["git", "clone", "--quiet", url, str(workdir)], check=True)
        subprocess.run(
            ["git", "-C", str(workdir), "checkout", "--quiet", ref],
            check=True,
        )
        if include is not None:
            copy_included_paths(workdir, destination, include)
        else:
            shutil.copytree(
                workdir,
                destination,
                ignore=shutil.ignore_patterns(".git", "__pycache__", "*.pyc"),
            )
    if not (destination / "SKILL.md").exists():
        raise SystemExit(
            f"External skill {destination.name} ({url}@{ref}) has no SKILL.md at repo root"
        )


def copy_included_paths(source: Path, destination: Path, include: list[str]) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    for name in include:
        src = source / name
        if not src.exists():
            raise SystemExit(f"External skill source missing required path: {name}")
        dst = destination / name
        if src.is_dir():
            shutil.copytree(
                src,
                dst,
                ignore=shutil.ignore_patterns(".git", "__pycache__", "*.pyc"),
            )
        else:
            shutil.copy2(src, dst)


def copy_hooks(plugin: str, platform: str) -> None:
    hook_name = hook_for(plugin, platform)
    if not hook_name:
        return
    src = HOOKS_CATALOG_DIR / hook_name
    if not src.exists():
        raise SystemExit(f"Missing hook catalog source: {src}")
    shutil.copytree(
        src,
        plugin_dir(plugin, platform) / "hooks",
        ignore=shutil.ignore_patterns("__pycache__", "*.pyc", PACKAGING_FILENAME),
    )


def claude_manifest(plugin: str) -> dict:
    metadata = PLUGIN_DEFS[plugin]
    return {
        "name": plugin,
        "description": metadata["description"],
        "version": plugin_version(plugin),
        "author": {
            "name": OWNER_NAME,
        },
    }


def codex_manifest(plugin: str) -> dict:
    metadata = PLUGIN_DEFS[plugin]
    return {
        "name": plugin,
        "version": plugin_version(plugin),
        "description": metadata["description"],
        "author": {
            "name": OWNER_NAME,
            "email": OWNER_EMAIL,
            "url": OWNER_URL,
        },
        "homepage": REPOSITORY_URL,
        "repository": REPOSITORY_URL,
        "license": LICENSE,
        "keywords": metadata["keywords"],
        **({"skills": "./skills/"} if metadata.get("skills") else {}),
        "interface": {
            "displayName": metadata["display_name"],
            "shortDescription": metadata["short_description"],
            "longDescription": metadata["long_description"],
            "developerName": OWNER_NAME,
            "category": metadata["category"],
            "capabilities": metadata["capabilities"],
            "websiteURL": REPOSITORY_URL,
            "privacyPolicyURL": PRIVACY_POLICY_URL,
            "termsOfServiceURL": TERMS_OF_SERVICE_URL,
            "defaultPrompt": metadata["default_prompts"],
            "brandColor": metadata["brand_color"],
            "composerIcon": "./assets/icon.png",
            "logo": "./assets/logo.png",
            "screenshots": [
                "./assets/screenshot-1.png",
                "./assets/screenshot-2.png",
                "./assets/screenshot-3.png",
            ],
        },
    }


def write_png(path: Path, width: int, height: int, pixels: bytearray) -> None:
    def chunk(tag: bytes, data: bytes) -> bytes:
        return (
            struct.pack(">I", len(data))
            + tag
            + data
            + struct.pack(">I", zlib.crc32(tag + data) & 0xFFFFFFFF)
        )

    raw = bytearray()
    stride = width * 3
    for row in range(height):
        raw.append(0)
        start = row * stride
        raw.extend(pixels[start : start + stride])

    payload = bytearray(b"\x89PNG\r\n\x1a\n")
    payload.extend(chunk(b"IHDR", struct.pack(">IIBBBBB", width, height, 8, 2, 0, 0, 0)))
    payload.extend(chunk(b"IDAT", zlib.compress(bytes(raw), level=9)))
    payload.extend(chunk(b"IEND", b""))
    path.write_bytes(bytes(payload))


def fill_gradient(pixels: bytearray, width: int, height: int, top: tuple[int, int, int], bottom: tuple[int, int, int]) -> None:
    for y in range(height):
        blend = y / max(height - 1, 1)
        r = int(top[0] * (1 - blend) + bottom[0] * blend)
        g = int(top[1] * (1 - blend) + bottom[1] * blend)
        b = int(top[2] * (1 - blend) + bottom[2] * blend)
        for x in range(width):
            offset = (y * width + x) * 3
            pixels[offset] = r
            pixels[offset + 1] = g
            pixels[offset + 2] = b


def draw_rect(
    pixels: bytearray,
    width: int,
    height: int,
    left: int,
    top: int,
    rect_width: int,
    rect_height: int,
    color: tuple[int, int, int],
) -> None:
    right = min(left + rect_width, width)
    bottom = min(top + rect_height, height)
    for y in range(max(top, 0), bottom):
        for x in range(max(left, 0), right):
            offset = (y * width + x) * 3
            pixels[offset] = color[0]
            pixels[offset + 1] = color[1]
            pixels[offset + 2] = color[2]


def draw_circle(
    pixels: bytearray,
    width: int,
    height: int,
    center_x: int,
    center_y: int,
    radius: int,
    color: tuple[int, int, int],
) -> None:
    radius_sq = radius * radius
    for y in range(max(center_y - radius, 0), min(center_y + radius, height - 1) + 1):
        for x in range(max(center_x - radius, 0), min(center_x + radius, width - 1) + 1):
            dx = x - center_x
            dy = y - center_y
            if dx * dx + dy * dy <= radius_sq:
                offset = (y * width + x) * 3
                pixels[offset] = color[0]
                pixels[offset + 1] = color[1]
                pixels[offset + 2] = color[2]


def blend_overlay(
    pixels: bytearray,
    width: int,
    height: int,
    color: tuple[int, int, int],
    step: int,
    alpha_num: int,
    alpha_den: int,
) -> None:
    for y in range(height):
        for x in range(width):
            if (x + y) % step != 0:
                continue
            offset = (y * width + x) * 3
            pixels[offset] = (pixels[offset] * (alpha_den - alpha_num) + color[0] * alpha_num) // alpha_den
            pixels[offset + 1] = (pixels[offset + 1] * (alpha_den - alpha_num) + color[1] * alpha_num) // alpha_den
            pixels[offset + 2] = (pixels[offset + 2] * (alpha_den - alpha_num) + color[2] * alpha_num) // alpha_den


def make_icon(path: Path, palette: dict[str, tuple[int, int, int]]) -> None:
    width = height = 256
    pixels = bytearray(width * height * 3)
    fill_gradient(pixels, width, height, palette["background"], palette["surface"])
    draw_circle(pixels, width, height, 84, 84, 48, palette["primary"])
    draw_circle(pixels, width, height, 172, 96, 34, palette["secondary"])
    draw_rect(pixels, width, height, 52, 148, 152, 34, palette["accent"])
    draw_rect(pixels, width, height, 76, 188, 104, 20, palette["secondary"])
    blend_overlay(pixels, width, height, (255, 255, 255), step=11, alpha_num=1, alpha_den=8)
    write_png(path, width, height, pixels)


def make_logo(path: Path, palette: dict[str, tuple[int, int, int]]) -> None:
    width = 1200
    height = 675
    pixels = bytearray(width * height * 3)
    fill_gradient(pixels, width, height, palette["background"], palette["surface"])
    draw_rect(pixels, width, height, 72, 72, 460, 531, palette["primary"])
    draw_rect(pixels, width, height, 558, 72, 570, 156, palette["secondary"])
    draw_rect(pixels, width, height, 558, 258, 420, 96, palette["accent"])
    draw_rect(pixels, width, height, 558, 396, 280, 68, palette["secondary"])
    draw_circle(pixels, width, height, 998, 496, 84, palette["accent"])
    blend_overlay(pixels, width, height, (255, 255, 255), step=19, alpha_num=1, alpha_den=12)
    write_png(path, width, height, pixels)


def make_screenshot(path: Path, palette: dict[str, tuple[int, int, int]], variant: int) -> None:
    width = 1440
    height = 900
    pixels = bytearray(width * height * 3)
    fill_gradient(pixels, width, height, palette["background"], palette["surface"])

    nav_width = 220 + variant * 18
    draw_rect(pixels, width, height, 0, 0, nav_width, height, palette["primary"])
    draw_rect(pixels, width, height, nav_width + 36, 54, width - nav_width - 92, 118, palette["surface"])
    draw_rect(pixels, width, height, nav_width + 36, 206, 410, 272, palette["secondary"])
    draw_rect(pixels, width, height, nav_width + 482, 206, width - nav_width - 518, 182, palette["accent"])
    draw_rect(pixels, width, height, nav_width + 482, 424, width - nav_width - 518, 244, palette["surface"])
    draw_rect(pixels, width, height, nav_width + 36, 516, 410, 152, palette["surface"])
    draw_rect(pixels, width, height, nav_width + 36, 712, width - nav_width - 92, 108, palette["secondary"])
    draw_circle(pixels, width, height, width - 124, 112, 36 + variant * 6, palette["accent"])

    for row in range(5):
        draw_rect(
            pixels,
            width,
            height,
            28,
            110 + row * 116,
            nav_width - 56,
            18,
            palette["background"],
        )

    blend_overlay(pixels, width, height, (255, 255, 255), step=17 - min(variant, 2) * 2, alpha_num=1, alpha_den=10)
    write_png(path, width, height, pixels)


def write_assets(plugin: str, platform: str) -> None:
    metadata = PLUGIN_DEFS[plugin]
    assets_dir = plugin_dir(plugin, platform) / "assets"
    assets_dir.mkdir(parents=True, exist_ok=True)
    palette = metadata["palette"]
    make_icon(assets_dir / "icon.png", palette)
    make_logo(assets_dir / "logo.png", palette)
    for variant in range(1, 4):
        make_screenshot(assets_dir / f"screenshot-{variant}.png", palette, variant)


def plugin_has_content(plugin: str, platform: str) -> bool:
    return (
        bool(skills_for(plugin, platform))
        or hook_for(plugin, platform) is not None
        or bool(external_skills_for(plugin, platform))
    )


def build_plugin(plugin: str, platform: str) -> bool:
    """Materialize <plugin> for <platform>. Returns True iff a dir was written."""
    if not plugin_has_content(plugin, platform):
        return False
    target = plugin_dir(plugin, platform)
    if target.exists():
        shutil.rmtree(target)
    manifest_dir = ".claude-plugin" if platform == "claude" else ".codex-plugin"
    (target / manifest_dir).mkdir(parents=True)
    if skills_for(plugin, platform) or external_skills_for(plugin, platform):
        (target / "skills").mkdir(parents=True, exist_ok=True)
        copy_skills(plugin, platform)
        fetch_external_skills(plugin, platform)
    copy_hooks(plugin, platform)
    write_assets(plugin, platform)
    manifest = claude_manifest(plugin) if platform == "claude" else codex_manifest(plugin)
    json_dump(target / manifest_dir / "plugin.json", manifest)
    return True


def write_claude_marketplace() -> None:
    local_entries = [
        {
            "name": plugin,
            "description": PLUGIN_DEFS[plugin]["description"],
            "version": plugin_version(plugin),
            "source": f"./plugins/claude/{plugin}",
            "author": {
                "name": OWNER_NAME,
            },
        }
        for plugin in PLUGIN_ORDER
        if plugin_has_content(plugin, "claude")
    ]
    external_entries = [
        {
            "name": ext["name"],
            "description": ext["description"],
            "source": {
                "source": "github",
                "repo": ext["repo"],
            },
            "author": {
                "name": OWNER_NAME,
            },
        }
        for ext in EXTERNAL_PLUGINS
    ]
    payload = {
        "name": "bento",
        "owner": {
            "name": OWNER_NAME,
        },
        "metadata": {
            "description": "Reusable coding-agent plugins packaged for Claude Code",
        },
        "plugins": local_entries + external_entries,
    }
    json_dump(CLAUDE_MARKETPLACE_FILE, payload)


def prune_generated_plugin_dirs() -> None:
    if PLUGINS_DIR.exists():
        shutil.rmtree(PLUGINS_DIR)
    PLUGINS_DIR.mkdir(parents=True)
    for platform in PLATFORMS:
        (PLUGINS_DIR / platform).mkdir(parents=True, exist_ok=True)


def run_verify_commands() -> None:
    subprocess.run(TEST_CMD, cwd=ROOT_DIR, check=True)
    if os.environ.get("BENTO_SKIP_CLAUDE_VALIDATE") == "1":
        return
    subprocess.run(CLAUDE_VALIDATE_CMD, cwd=ROOT_DIR, check=True)


def build_repo(run_verification: bool = True) -> None:
    prune_generated_plugin_dirs()
    for plugin in PLUGIN_ORDER:
        for platform in PLATFORMS:
            build_plugin(plugin, platform)
    write_claude_marketplace()
    if run_verification:
        run_verify_commands()


def main() -> None:
    run_verification = os.environ.get("BENTO_SKIP_VERIFY") != "1"
    build_repo(run_verification=run_verification)


if __name__ == "__main__":
    main()
