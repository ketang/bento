{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/scripts/permission-request.py bento ${PLUGIN_ROOT}",
            "statusMessage": "Checking Bento helper approval"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/scripts/seed-agent-plugins.py ${PLUGIN_ROOT}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/scripts/record-bash.py",
            "statusMessage": "Recording Bento helper telemetry"
          }
        ]
      }
    ]
  }
}
